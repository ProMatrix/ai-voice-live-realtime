/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "paths": {
      "llm-common": ["./projects/llm-common/src/public-api"],
      "llm-google": ["./projects/llm-google/src/public-api"],
      "llm-microsoft": ["./projects/llm-microsoft/src/public-api"],
      "shared-ux": ["./projects/shared-ux/src/public-api"]
    },
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve"
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  },
  "files": [],
  "references": [
    {
      "path": "./projects/llm-common/tsconfig.lib.json"
    },
    {
      "path": "./projects/llm-common/tsconfig.spec.json"
    },
    {
      "path": "./projects/llm-microsoft/tsconfig.lib.json"
    },
    {
      "path": "./projects/llm-microsoft/tsconfig.spec.json"
    },
    {
      "path": "./projects/llm-google/tsconfig.lib.json"
    },
    {
      "path": "./projects/llm-google/tsconfig.spec.json"
    },
    {
      "path": "./projects/shared-ux/tsconfig.lib.json"
    },
    {
      "path": "./projects/shared-ux/tsconfig.spec.json"
    },
    {
      "path": "./projects/host-azure-voice/tsconfig.app.json"
    },
    {
      "path": "./projects/host-azure-voice/tsconfig.spec.json"
    },
    {
      "path": "./projects/host-gemini-voice/tsconfig.app.json"
    },
    {
      "path": "./projects/host-gemini-voice/tsconfig.spec.json"
    }
  ]
}
